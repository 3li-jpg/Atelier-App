# Atelier control plane (apps/api) — copy to .env or set in your shell / fly secrets
MASTER_KEY=change-me            # encrypts stored provider API keys (AES-256-GCM)
AUTH_TOKEN=                     # optional; if set, public routes require this bearer (owner/admin backdoor)
# GitHub OAuth (handoff T3) — leave unset to run owner-alpha with AUTH_TOKEN instead
SESSION_SECRET=                 # HMAC key for session cookies; falls back to MASTER_KEY
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
PUBLIC_WEB_URL=                 # browser-facing origin (OAuth redirect); defaults to PUBLIC_URL
PORT=3000
DB_PATH=atelier.db              # sqlite file; ":memory:" for throwaway
DATABASE_URL=                   # optional Postgres (e.g. Supabase); overrides sqlite when set.
                                # Supabase: use the "Transaction pooler" URI (port 6543)
PUBLIC_URL=http://localhost:3000  # must be reachable FROM sandbox machines (tunnel or deploy)

# Fly sandbox substrate
FLY_SANDBOX_APP=atelier-sandboxes
FLY_SANDBOX_TOKEN=              # fly tokens create deploy -a atelier-sandboxes
RUNNER_IMAGE=registry.fly.io/atelier-sandboxes:runner-v1

# Git access for the agent (interim — per-repo GitHub App tokens replace this, handoff T5)
GIT_TOKEN=

# Hibernation tuning (ms) — see handoff-openchamber.md (suspend fuse must
# exceed the workspace proxy's 60s activity-ping throttle)
#SUSPEND_AFTER_MS=300000
#REAPER_INTERVAL_MS=60000
